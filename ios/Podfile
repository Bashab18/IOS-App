# iOS 16.0 — minimum for iOS 26 era devices (iPhone XS and later)
# Xcode 26 / iOS 26 SDK requires iOS 13+ to build; 16.0 ensures arm64-only
# and aligns with the device range iOS 26 itself supports.
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously, affecting build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      # ── Deployment target ──────────────────────────────────────────
      # Enforce across all pods so workmanager_apple and others don't
      # raise a "requires higher minimum iOS version" error.
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'

      # ── Bitcode ────────────────────────────────────────────────────
      # Bitcode was deprecated in Xcode 14, fully removed in Xcode 26.
      # Explicitly disable to prevent linker warnings.
      config.build_settings['ENABLE_BITCODE'] = 'NO'

      # ── Swift concurrency (Xcode 26 / Swift 6) ─────────────────────
      # Suppress strict concurrency errors in pod targets that have not
      # yet migrated to Swift 6. Our own code uses SWIFT_STRICT_CONCURRENCY
      # = minimal (set in project.pbxproj).
      config.build_settings['SWIFT_STRICT_CONCURRENCY'] = 'minimal'

      # ── Module stability (arm64 simulator on Apple Silicon) ─────────
      # Required so Swift pods expose stable ABI when built for
      # arm64-iphonesimulator on M-series Macs (Codemagic mac_mini_m2).
      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
    end
  end
end
